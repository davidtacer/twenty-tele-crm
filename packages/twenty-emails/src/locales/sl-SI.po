#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "Suspended Workspace"
msgstr "Ustavljeno delovno okolje"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
#: src/emails/password-update-notify.email.tsx
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Dear {userName},"
msgstr "Spoštovani {userName},"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
#: src/emails/password-update-notify.email.tsx
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Hello,"
msgstr "Pozdravljeni,"

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "It appears that your workspace <0>{workspaceDisplayName}</0> has been suspended for {daysSinceInactive} days."
msgstr "Zdi se, da je bilo vaše delovno okolje <0>{workspaceDisplayName}</0> ustavljeno že {daysSinceInactive} dni."

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "The workspace will be deactivated in {remainingDays} {dayOrDays}, and all its data will be deleted."
msgstr "Delovno okolje bo deaktivirano čez {remainingDays} {dayOrDays}, in vsi podatki bodo izbrisani."

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "If you wish to continue using Twenty, please update your subscription within the next {remainingDays} {dayOrDays}."
msgstr "Če želite nadaljevati z uporabo Twenty, prosimo, posodobite svojo naročnino v naslednjih {remainingDays} {dayOrDays}."

#. js-lingui-explicit-id
#: src/emails/warn-suspended-workspace.email.tsx
msgid "Update your subscription"
msgstr "Posodobite svojo naročnino"

#. js-lingui-explicit-id
#: src/emails/validate-approved-access-domain.email.tsx
#: src/emails/validate-approved-access-domain.email.tsx
msgid "Validate domain"
msgstr "Preverite domeno"

#. js-lingui-explicit-id
#: src/emails/validate-approved-access-domain.email.tsx
msgid "{senderName} (<0>{senderEmail}</0>): Please validate this domain to allow users with <1>@{domain}</1> email addresses to join your workspace without requiring an invitation."
msgstr "{senderName} (<0>{senderEmail}</0>): Prosimo, preverite to domeno, da omogočite uporabnikom z <1>@{domain}</1> e-poštnimi naslovi, da se pridružijo vašemu delovnemu okolju brez povabila."

#. js-lingui-explicit-id
#: src/emails/test.email.tsx
msgid "Test email"
msgstr "Preizkusite e-pošto"

#. js-lingui-explicit-id
#: src/emails/send-invite-link.email.tsx
msgid "Join your team on Twenty"
msgstr "Pridružite se svoji ekipi na Twenty"

#. js-lingui-explicit-id
#: src/emails/send-invite-link.email.tsx
msgid "{senderName} (<0>{senderEmail}</0>) has invited you to join a workspace called <1>{workspaceName}</1>."
msgstr "{senderName} (<0>{senderEmail}</0>) vas je povabil, da se pridružite delovnemu okolju z imenom <1>{workspaceName}</1>."

#. js-lingui-explicit-id
#: src/emails/send-invite-link.email.tsx
msgid "Accept invite"
msgstr "Sprejmite povabilo"

#. js-lingui-explicit-id
#: src/emails/send-email-verification-link.email.tsx
msgid "Confirm your new email address"
msgstr "Potrdite svoj novi e-poštni naslov"

#. js-lingui-explicit-id
#: src/emails/send-email-verification-link.email.tsx
msgid "Confirm your email address"
msgstr "Potrdite svoj e-poštni naslov"

#. js-lingui-explicit-id
#: src/emails/send-email-verification-link.email.tsx
msgid "Confirm new email"
msgstr "Potrdite nov e-poštni naslov"

#. js-lingui-explicit-id
#: src/emails/send-email-verification-link.email.tsx
msgid "Verify Email"
msgstr "Preverite e-pošto"

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "Password updated"
msgstr "Geslo posodobljeno"

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "This is a confirmation that password for your account ({email}) was successfully changed on {formattedDate}."
msgstr "To je potrditev, da je bilo geslo za vaš račun ({email}) uspešno spremenjeno dne {formattedDate}."

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "If you did not initiate this change, please contact your workspace owner immediately."
msgstr "Če te spremembe niste sprožili vi, se takoj obrnite na lastnika vašega delovnega okolja."

#. js-lingui-explicit-id
#: src/emails/password-update-notify.email.tsx
msgid "Connect to Twenty"
msgstr "Povežite se s Twenty"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Reset your password 🗝"
msgstr "Ponastavite svoje geslo 🗝"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Set your password 🗝"
msgstr "Nastavite svoje geslo 🗝"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Reset"
msgstr "Ponastavi"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "Set"
msgstr "Nastavi"

#. js-lingui-explicit-id
#: src/emails/password-reset-link.email.tsx
msgid "This link is only valid for the next {duration}. If the link does not work, you can use the login verification link directly:"
msgstr "Ta povezava je veljavna le naslednjih {duration}. Če povezava ne deluje, lahko neposredno uporabite povezavo za preverjanje prijave:"

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Deleted Workspace"
msgstr "Izbrisano delovno okolje"

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Your workspace <0>{workspaceDisplayName}</0> has been deleted as your subscription expired {daysSinceInactive} days ago."
msgstr "Vaše delovno okolje <0>{workspaceDisplayName}</0> je bilo izbrisano, ker je vaša naročnina potekla pred {daysSinceInactive} dnevi."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "All data in this workspace has been permanently deleted."
msgstr "Vsi podatki v tem delovnem okolju so bili trajno izbrisani."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "If you wish to use Twenty again, you can create a new workspace."
msgstr "Če želite ponovno uporabljati Twenty, lahko ustvarite novo delovno okolje."

#. js-lingui-explicit-id
#: src/emails/clean-suspended-workspace.email.tsx
msgid "Create a new workspace"
msgstr "Ustvarite novo delovno okolje"

